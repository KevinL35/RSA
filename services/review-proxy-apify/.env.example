# Apify（仅本服务使用，勿提交）
APIFY_TOKEN=
# 商店 Actor ID，如 owner~amazon-reviews-scraper
APIFY_ACTOR_ID=

# 与 RSA 任务里 platform=amazon 时，把 product_id 当作 ASIN：
# asins → {"asins":[ASIN],"maxReviews":N}
# productUrls → {"productUrls":[{"url":"https://www.amazon.com/dp/ASIN"}],"maxReviews":N}
APIFY_INPUT_STYLE=asins
APIFY_MAX_REVIEWS=50
# run-sync-get-dataset-items 最长 300s（Apify 文档）
APIFY_RUN_TIMEOUT_SECONDS=240

# 若设置，则 RSA 的 REVIEW_PROVIDER_API_KEY 必须与本值一致（Bearer）
REVIEW_PROXY_API_KEY=
