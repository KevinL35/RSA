DEEPSEEK_API_KEY=sk-replace-me
# OpenAI SDK 兼容基址（勿带 /chat/completions）
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-reasoner
# 单次请求最多送多少条评论（防超长 context，上限 50）
DEEPSEEK_MAX_REVIEWS_PER_CALL=25
# 可选：platform-api 的 ANALYSIS_PROVIDER_API_KEY 填同一值，适配层校验 Bearer
ADAPTER_SHARED_SECRET=
ADAPTER_HOST=0.0.0.0
ADAPTER_PORT=9100
