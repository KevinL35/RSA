# 复制为 apps/api/.env 后填写

# Project URL（以 https:// 开头、.supabase.co 结尾）；勿将 anon / service_role 的 JWT 填到 URL 一行
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# 逗号分隔，开发时与 Vite 端口一致
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# TB-2 评论抓取
# mode=http（默认）：POST REVIEW_PROVIDER_URL，body { platform, product_id }；可选 REVIEW_PROVIDER_API_KEY → Bearer
# mode=apify：直连 Apify sync dataset，需 APIFY_TOKEN + APIFY_ACTOR_ID
# mode=pangolin：Pangolinfo Amazon Review API，需 PANGOLIN_TOKEN（文档见 docs/runbooks/pangolin-amazon-reviews.md）
REVIEW_PROVIDER_MODE=http
REVIEW_PROVIDER_URL=
REVIEW_PROVIDER_API_KEY=
REVIEW_PROVIDER_TIMEOUT_SECONDS=30
REVIEW_FETCH_MAX_RETRIES=3
# 无真实 API 时 true，返回占位评论
REVIEW_PROVIDER_MOCK=false
# 仅 REVIEW_PROVIDER_MODE=apify 时生效（Amazon Actor：asins 或 productUrls）
APIFY_TOKEN=
APIFY_ACTOR_ID=
APIFY_INPUT_STYLE=asins
APIFY_MAX_REVIEWS=50
APIFY_RUN_TIMEOUT_SECONDS=240

# 仅 REVIEW_PROVIDER_MODE=pangolin 时生效（POST https://scrapeapi.pangolinfo.com/api/v1/scrape）
PANGOLIN_TOKEN=
PANGOLIN_BASE_URL=https://scrapeapi.pangolinfo.com
PANGOLIN_AMAZON_URL=https://www.amazon.com
PANGOLIN_PAGE_COUNT=1
PANGOLIN_FILTER_BY_STAR=all_stars
PANGOLIN_SORT_BY=recent
PANGOLIN_PARSER_NAME=amzReviewV2
PANGOLIN_TIMEOUT_SECONDS=180

# TB-3 分析源：POST 见 README；多路由示例：
# ANALYSIS_PROVIDER_ROUTES_JSON={"default":"https://example.com/analyze"}
ANALYSIS_PROVIDER_URL=
ANALYSIS_PROVIDER_DEFAULT_ID=default
ANALYSIS_PROVIDER_ROUTES_JSON=
ANALYSIS_PROVIDER_API_KEY=
ANALYSIS_PROVIDER_TIMEOUT_SECONDS=120
ANALYSIS_MAX_RETRIES=2
ANALYSIS_PROVIDER_MOCK=false

# TB-11 可选翻译（LibreTranslate 兼容 POST：q, source, target, format）；未配置则前端仅展示英文
TRANSLATION_API_URL=
TRANSLATION_API_KEY=
