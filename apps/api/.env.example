# 复制为 apps/api/.env 后填写

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# 逗号分隔，开发时与 Vite 端口一致
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# TB-2 评论抓取：POST JSON { "platform", "product_id" }；可选 Bearer
REVIEW_PROVIDER_URL=
REVIEW_PROVIDER_API_KEY=
REVIEW_PROVIDER_TIMEOUT_SECONDS=30
REVIEW_FETCH_MAX_RETRIES=3
# 无真实 API 时 true，返回占位评论
REVIEW_PROVIDER_MOCK=false
