# 复制为同目录下的 `.env` 并填写真实值（勿提交 Git）。
# 完整清单见 docs/runbooks/env-to-run.md

# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=

# === Pangolin 抓评论（REVIEW_PROVIDER_MODE=pangolin）===
# 列表页数：只改 .env 即可，无需改代码。Pydantic 会读取 PANGOLIN_PAGE_COUNT 覆盖代码默认。
PANGOLIN_PAGE_COUNT=10
# 发往 Pangolin 的 pageCount 上限（防误配过大；需更大时在此改）
PANGOLIN_PAGE_COUNT_MAX=100
# PANGOLIN_TOKEN=
# PANGOLIN_AMAZON_URL=https://www.amazon.com
